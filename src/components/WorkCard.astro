---
interface Props {
  title: string;
  description: string;
  tags: string[];
  repo?: string;
  url?: string;
}

const { title, description, tags, repo, url } = Astro.props;
const href = url ?? repo;
---

<article class="group relative rounded-sm border border-line bg-ink-2/60 p-5 transition-colors hover:border-accent/70">
  <h3 class="font-mono font-bold">
    {href ? (
      <a href={href} target="_blank" rel="noopener" class="after:absolute after:inset-0 group-hover:text-accent">
        {title}
      </a>
    ) : (
      title
    )}
  </h3>
  <p class="mt-2 text-sm leading-relaxed text-muted">{description}</p>
  {tags.length > 0 && (
    <ul class="mt-3 flex flex-wrap gap-2 font-mono text-xs text-teal">
      {tags.map((tag) => <li>[{tag}]</li>)}
    </ul>
  )}
</article>
