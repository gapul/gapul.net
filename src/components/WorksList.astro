---
import { getCollection } from 'astro:content';
import type { Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const works = (await getCollection('works')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

{works.length > 0 ? (
  <ul class="space-y-6 pb-24">
    {works.map(({ data }) => (
      <li>
        <a href={data.url ?? data.repo} target="_blank" rel="noopener" class="hover:text-accent">
          {data.title}
        </a>
        <p class="mt-1 text-sm leading-relaxed text-muted">
          {locale === 'en' ? (data.descriptionEn ?? data.description) : data.description}
        </p>
        {data.tags.length > 0 && (
          <p class="mt-1 font-mono text-xs text-muted">{data.tags.join(' · ')}</p>
        )}
      </li>
    ))}
  </ul>
) : (
  <p class="pb-24 text-muted">{locale === 'en' ? 'Coming soon.' : '準備中。'}</p>
)}
