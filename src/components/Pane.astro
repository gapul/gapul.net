---
// 四隅に「+」を置いた ghostty 風ボーダーペイン
interface Props {
  title?: string;
  id?: string;
  class?: string;
}

const { title, id, class: cls } = Astro.props;
---

<section {id} class:list={['pane', cls]}>
  <span class="corners" aria-hidden="true"></span>
  {title && <h2 class="pane-title prompt">{title}</h2>}
  <div class="pane-body">
    <slot />
  </div>
</section>

<style>
  .pane {
    position: relative;
    border: 1px solid var(--color-line);
    background: color-mix(in srgb, var(--color-ink) 82%, transparent);
    scroll-margin-top: 6rem;
  }

  /* 四隅の + 記号 */
  .pane::before,
  .pane::after,
  .corners::before,
  .corners::after {
    content: '+';
    position: absolute;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1;
    color: #4c4c50;
    background: var(--color-ink);
    padding: 0 1px;
  }

  .pane::before { top: -0.5em; left: -0.4ch; }
  .pane::after { top: -0.5em; right: -0.4ch; }
  .corners::before { bottom: -0.5em; left: -0.4ch; }
  .corners::after { bottom: -0.5em; right: -0.4ch; }

  .pane:hover::before,
  .pane:hover::after,
  .pane:hover .corners::before,
  .pane:hover .corners::after {
    color: var(--color-accent);
  }

  .pane-title {
    position: absolute;
    top: -0.75em;
    left: 1.25rem;
    padding: 0 0.75ch;
    background: var(--color-ink);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: var(--color-green);
  }

  .pane-body {
    padding: 1.75rem 1.5rem;
  }
</style>
