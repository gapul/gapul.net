---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { formatDateJST } from '../../../lib/date';
import { STRINGS } from '../../../lib/i18n';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<Base lang="en" title="Blog" description={STRINGS.en.blogDescription} altHref="/blog/">
  <h1 class="pt-20 pb-10 font-mono text-2xl font-bold">blog</h1>
  <ul class="max-w-2xl space-y-3 pb-24">
    {posts.map((post) => (
      <li class="flex flex-wrap items-baseline gap-x-4">
        <time datetime={post.data.pubDate.toISOString()} class="font-mono text-sm text-muted">
          {formatDateJST(post.data.pubDate)}
        </time>
        <a href={`/blog/${post.id}/`} class="hover:text-accent">{post.data.title}</a>
      </li>
    ))}
  </ul>
</Base>
