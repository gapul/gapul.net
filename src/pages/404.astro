---
import Base from '../layouts/Base.astro';
---

<Base title="404">
  <section class="flex flex-1 flex-col justify-center">
    <h1 class="font-mono text-[clamp(4rem,15vw,10rem)] leading-none font-bold tracking-tight">
      404<span class="text-accent">.</span>
    </h1>
    <p class="mt-8 text-muted">ページが見つかりませんでした。 / Page not found.</p>
    <p class="mt-10">
      <a href="/" class="text-lg font-bold hover:text-accent">Home →</a>
    </p>
  </section>
</Base>
