---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { formatDateJST } from '../../lib/date';
import { STRINGS } from '../../lib/i18n';
import { RSS } from '../../lib/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<Base lang="ja" title="Blog" description={STRINGS.ja.blogDescription} altHref="/en/blog/">
  <div class="flex items-center gap-4 pt-20 pb-10">
    <h1 class="font-mono text-2xl font-bold">blog</h1>
    <a href={RSS.href} aria-label="RSS" class="text-muted transition-colors hover:text-accent">
      <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
        <path d={RSS.icon} />
      </svg>
    </a>
  </div>
  <ul class="max-w-2xl space-y-3 pb-24">
    {posts.map((post) => (
      <li class="flex flex-wrap items-baseline gap-x-4">
        <time datetime={post.data.pubDate.toISOString()} class="font-mono text-sm text-muted">
          {formatDateJST(post.data.pubDate)}
        </time>
        <a href={`/blog/${post.id}/`} class="hover:text-accent">{post.data.title}</a>
      </li>
    ))}
  </ul>
</Base>
