---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Pane from '../components/Pane.astro';
import WorkCard from '../components/WorkCard.astro';
import { LINKS } from '../lib/site';
import { formatDateJST } from '../lib/date';

const works = (await getCollection('works')).sort(
  (a, b) => a.data.order - b.data.order,
);
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

// ANSI Shadow „Āģ "GAPUL"
const logo = String.raw`
 ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó
‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ
‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ
‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ
‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
 ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ      ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ
`.trim();
---

<Base>
  <!-- Hero: ASCII„É≠„āī + „āŅ„Éľ„Éü„Éä„Éę„Éá„ÉĘ -->
  <section class="py-16">
    <pre class="logo font-mono" aria-hidden="true">{logo}</pre>
    <h1 class="sr-only">gapul</h1>
    <p class="mt-6 text-xl font-bold">„Ā§„ĀŹ„Ā£„Ā¶„ÄĀ„Āā„ĀĚ„Ā∂„Äā</p>
    <p class="mt-3 max-w-xl leading-relaxed text-muted">
      „ā§„É≥„āŅ„É©„āĮ„ÉÜ„ā£„ÉĖ„Ā™šĹúŚďĀ„Ā®„ÉĄ„Éľ„Éę„āí„Ā§„ĀŹ„Ā£„Ā¶„ĀĄ„Āĺ„Āô„Äā
      „Éó„É≠„āł„āß„āĮ„ā∑„Éß„É≥„ÄĀ„Éć„ā§„ÉÜ„ā£„ÉĖ„āĘ„Éó„É™„ÄĀŤá™ŚģÖ„āĶ„Éľ„Éź„Éľ„Āĺ„āŹ„āä„Ā™„Ā©„Äā
    </p>

    <div class="terminal mt-10 font-mono text-sm">
      <div class="terminal-bar">
        <span class="dot" style="background:#ff605c"></span>
        <span class="dot" style="background:#ffbd44"></span>
        <span class="dot" style="background:#00ca4e"></span>
        <span class="terminal-title">gapul@gapul.net: ~</span>
      </div>
      <div class="terminal-body">
        <p><span class="ps1">$</span> whoami</p>
        <p class="out">gapul</p>
        <p class="mt-3"><span class="ps1">$</span> ls ~/works</p>
        <p class="out">{works.length > 0 ? works.map((w) => w.id).join('  ') : '(śļĖŚāôšł≠)'}</p>
        <p class="mt-3 cursor"><span class="ps1">$</span></p>
      </div>
    </div>
  </section>

  <div class="space-y-12 pb-8">
    <Pane id="works" title="ls works/">
      {works.length > 0 ? (
        <div class="grid gap-4 sm:grid-cols-2">
          {works.map(({ data }) => <WorkCard {...data} />)}
        </div>
      ) : (
        <p class="font-mono text-muted">śļĖŚāôšł≠„Äā</p>
      )}
    </Pane>

    {posts.length > 0 && (
      <Pane title="tail -3 blog.log">
        <ul class="space-y-3">
          {posts.map((post) => (
            <li class="flex flex-wrap items-baseline gap-x-4">
              <time datetime={post.data.pubDate.toISOString()} class="font-mono text-sm text-muted">
                {formatDateJST(post.data.pubDate)}
              </time>
              <a href={`/blog/${post.id}/`} class="font-bold hover:text-accent">{post.data.title}</a>
            </li>
          ))}
        </ul>
        <p class="mt-5"><a href="/blog" class="font-mono text-sm text-muted hover:text-paper">‚Üí „Āô„ĀĻ„Ā¶„ĀģŤ®ėšļč</a></p>
      </Pane>
    )}

    <Pane id="links" title="cat links.txt">
      <ul class="space-y-3 font-mono text-sm">
        {LINKS.map((link) => (
          <li class="flex flex-wrap items-baseline gap-x-3">
            <span class="w-20 text-teal">{link.label.toLowerCase()}</span>
            <span class="text-muted">‚Üí</span>
            <a href={link.href} target="_blank" rel="noopener me" class="hover:text-accent">
              {link.note}
            </a>
          </li>
        ))}
      </ul>
    </Pane>
  </div>
</Base>

<style>
  /* ghosttyťĘ®: ASCII„É≠„āī„Āę„ÉĖ„Éę„Éľ‚Üí„ÉĎ„Éľ„Éó„Éę„Āģ„āį„É©„Éá„Éľ„ā∑„Éß„É≥ */
  .logo {
    font-size: clamp(0.45rem, 1.8vw, 0.85rem);
    line-height: 1.15;
    background: linear-gradient(180deg, var(--color-accent) 20%, var(--color-accent-2));
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    filter: drop-shadow(0 0 24px color-mix(in srgb, var(--color-accent) 45%, transparent));
    overflow-x: auto;
  }

  .terminal {
    border: 1px solid var(--color-line);
    border-radius: 0.6rem;
    overflow: hidden;
    background: var(--color-ink-2);
    box-shadow: 0 20px 60px rgb(0 0 0 / 0.45);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.9rem;
    background: color-mix(in srgb, var(--color-paper) 5%, var(--color-ink-2));
    border-bottom: 1px solid var(--color-line);
  }

  .dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 9999px;
  }

  .terminal-title {
    margin-left: 0.5rem;
    font-size: 0.72rem;
    color: var(--color-muted);
  }

  .terminal-body {
    padding: 1.4rem;
    line-height: 1.9;
  }

  .ps1 {
    color: var(--color-green);
    user-select: none;
  }

  .out {
    color: var(--color-muted);
  }
</style>
