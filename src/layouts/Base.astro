---
import '@fontsource/zen-kaku-gothic-new/400.css';
import '@fontsource/zen-kaku-gothic-new/500.css';
import '@fontsource/zen-kaku-gothic-new/700.css';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import { SITE } from '../lib/site';
import { STRINGS, type Locale } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  lang?: Locale;
  altHref?: string; // 対になる言語版ページ(あればスイッチャーを出す)
}

const { title, lang = 'ja', description = STRINGS[lang].description, altHref } = Astro.props;
const pageTitle = title ? `${title} | ${SITE.title}` : SITE.title;
const canonical = new URL(Astro.url.pathname, SITE.url);
const path = Astro.url.pathname;
const home = lang === 'en' ? '/en/' : '/';
const works = lang === 'en' ? '/en/works/' : '/works/';
const blog = lang === 'en' ? '/en/blog/' : '/blog/';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {altHref && (
      <>
        <link rel="alternate" hreflang={lang === 'ja' ? 'en' : 'ja'} href={new URL(altHref, SITE.url)} />
        <link rel="alternate" hreflang={lang} href={canonical} />
      </>
    )}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.title} />
    <meta name="twitter:card" content="summary" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="flex min-h-dvh flex-col antialiased">
    <header class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-2 px-6 pt-8 text-base sm:px-12">
      <a href={home} class="font-mono text-muted hover:text-paper">gapul.net</a>
      <nav class="flex items-baseline gap-4 text-muted sm:gap-5">
        <a href={home} class:list={['hover:text-paper', path === home && 'text-paper']}>home</a>
        <a href={works} class:list={['hover:text-paper', path.startsWith(works) && 'text-paper']}>works</a>
        <a href={blog} class:list={['hover:text-paper', (path.startsWith('/blog') || path.startsWith('/en/blog')) && 'text-paper']}>blog</a>
        {altHref && (
          <a href={altHref} class="font-mono text-sm" aria-label={lang === 'ja' ? 'Switch to English' : '日本語に切り替え'}>
            <span class:list={[lang === 'ja' ? 'text-paper' : 'hover:text-paper']}>JP</span>
            <span> / </span>
            <span class:list={[lang === 'en' ? 'text-paper' : 'hover:text-paper']}>EN</span>
          </a>
        )}
      </nav>
    </header>
    <main class="flex flex-1 flex-col px-6 sm:px-12">
      <slot />
    </main>
    <footer class="flex items-baseline justify-between px-6 pb-8 text-xs text-muted sm:px-12">
      <p>© {new Date().getFullYear()} gapul</p>
      <a href="/rss.xml" class="font-mono hover:text-paper">rss</a>
    </footer>
  </body>
</html>
